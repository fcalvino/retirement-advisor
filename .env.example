# ============================================================
# Retirement Advisor — configuración de entorno
# Copiá este archivo a .env y completá los valores
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# AI (opcional — el sistema funciona sin esto con motor rule-based)
# ------------------------------------------------------------
AI_ENABLED=false
# Proveedor: claude | openai | xai | nous
# Para analizar BTC con Grok → AI_PROVIDER=xai, AI_MODEL=grok-3
AI_PROVIDER=claude

# Modelo según proveedor:
#   claude → claude-sonnet-4-6 | claude-opus-4-7
#   xai    → grok-3 | grok-2-1212
#   openai → gpt-4o | gpt-4o-mini
AI_MODEL=claude-sonnet-4-6

# Clave del proveedor seleccionado (completar SOLO la que corresponde al AI_PROVIDER activo)
ANTHROPIC_API_KEY=sk-ant-...
# XAI_API_KEY=xai-...           # Activar para Grok — reemplaza a ANTHROPIC_API_KEY
# OPENAI_API_KEY=sk-...
# NOUS_API_KEY=...

# Hermes OAuth — alternativa a API key para xAI/Nous (sin necesidad de XAI_API_KEY)
# HERMES_OAUTH_ENABLED=true

# Para BTC con Grok via Hermes OAuth:
#   1. hermes auth add xai-oauth
#   2. AI_PROVIDER=xai  AI_MODEL=grok-3  AI_ENABLED=true  (sin XAI_API_KEY)

# ------------------------------------------------------------
# Cache
# ------------------------------------------------------------
# Tiempo de vida del cache en horas. Recomendado: 24.
# Rango válido: 1–168 (1 semana)
CACHE_TTL_HOURS=24

# ------------------------------------------------------------
# Alertas por email (opcional)
# ------------------------------------------------------------
EMAIL_FROM=your@email.com
EMAIL_TO=destination@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Para Gmail: generá una App Password en myaccount.google.com/apppasswords
SMTP_PASSWORD=your_app_password

# ------------------------------------------------------------
# Alertas por Telegram (opcional)
# ------------------------------------------------------------
# Creá un bot con @BotFather y obtenés el token
TELEGRAM_TOKEN=your_bot_token
# Enviá un mensaje al bot y visitá api.telegram.org/bot<TOKEN>/getUpdates para obtener el chat_id
TELEGRAM_CHAT_ID=your_chat_id

# ------------------------------------------------------------
# Scheduler
# ------------------------------------------------------------
# Día del mes para generar el reporte PDF mensual (1–28)
REPORT_DAY=1
# Cada cuántas horas correr el chequeo de alertas
ALERT_INTERVAL_HOURS=24
