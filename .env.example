# ============================================================
# Retirement Advisor — configuración de entorno
# Copiá este archivo a .env y completá los valores
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# AI (opcional — el sistema funciona sin esto con motor rule-based)
# ------------------------------------------------------------
AI_ENABLED=false
# Proveedor: claude | openai | xai | nous
AI_PROVIDER=claude

# Clave del proveedor seleccionado (solo completar la que corresponda)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# XAI_API_KEY=xai-...   # No necesaria si usás Hermes OAuth (ver abajo)
# NOUS_API_KEY=...       # No necesaria si usás Hermes OAuth (ver abajo)

# Hermes OAuth — alternativa a API key para xAI/Nous
# Activar si ya estás autenticado vía Hermes OAuth (no se necesita XAI_API_KEY)
# HERMES_OAUTH_ENABLED=true
# XAI_AUTH_TOKEN=        # Token de sesión OAuth (opcional, alternativa a HERMES_OAUTH_ENABLED)

# ------------------------------------------------------------
# Cache
# ------------------------------------------------------------
# Tiempo de vida del cache en horas. Recomendado: 24.
# Rango válido: 1–168 (1 semana)
CACHE_TTL_HOURS=24

# ------------------------------------------------------------
# Alertas por email (opcional)
# ------------------------------------------------------------
EMAIL_FROM=your@email.com
EMAIL_TO=destination@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Para Gmail: generá una App Password en myaccount.google.com/apppasswords
SMTP_PASSWORD=your_app_password

# ------------------------------------------------------------
# Alertas por Telegram (opcional)
# ------------------------------------------------------------
# Creá un bot con @BotFather y obtenés el token
TELEGRAM_TOKEN=your_bot_token
# Enviá un mensaje al bot y visitá api.telegram.org/bot<TOKEN>/getUpdates para obtener el chat_id
TELEGRAM_CHAT_ID=your_chat_id

# ------------------------------------------------------------
# Scheduler
# ------------------------------------------------------------
# Día del mes para generar el reporte PDF mensual (1–28)
REPORT_DAY=1
# Cada cuántas horas correr el chequeo de alertas
ALERT_INTERVAL_HOURS=24
